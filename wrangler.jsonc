{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "monies-map",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-03",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "monies-map",
      "database_id": "d1aa440c-d239-48ac-b0a6-d39f34e26e0e"
    }
  ],
  "observability": {
    "enabled": true
  }
}
