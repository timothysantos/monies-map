{
  "name": "monies-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/ensure-node-major.mjs 22",
    "predev:api": "node ./scripts/ensure-node-major.mjs 22",
    "predev:ui": "node ./scripts/ensure-node-major.mjs 22",
    "prebuild": "node ./scripts/ensure-node-major.mjs 22",
    "prepreview": "node ./scripts/ensure-node-major.mjs 22",
    "predeploy": "node ./scripts/ensure-node-major.mjs 22",
    "predeploy:prod": "node ./scripts/ensure-node-major.mjs 22",
    "predeploy:demo": "node ./scripts/ensure-node-major.mjs 22",
    "predeploy:all": "node ./scripts/ensure-node-major.mjs 22",
    "predb:migrate": "node ./scripts/ensure-node-major.mjs 22",
    "predb:migrate:remote": "node ./scripts/ensure-node-major.mjs 22",
    "predb:migrate:demo": "node ./scripts/ensure-node-major.mjs 22",
    "pretest:e2e": "node ./scripts/ensure-node-major.mjs 22",
    "dev": "concurrently -k -n API,UI \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "wrangler dev --port 8787",
    "dev:ui": "vite",
    "build": "vite build",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "deploy": "npm run deploy:prod",
    "deploy:prod": "npm run build && wrangler deploy",
    "deploy:demo": "npm run build && wrangler deploy --config wrangler.demo.jsonc",
    "deploy:all": "npm run build && wrangler deploy && wrangler deploy --config wrangler.demo.jsonc",
    "db:migrate": "wrangler d1 execute monies-map --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute monies-map --remote --file=schema.sql",
    "db:migrate:demo": "wrangler d1 execute monies-map-demo --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260402.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "wrangler": "4.11.1"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "lucide-react": "^1.7.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  }
}
