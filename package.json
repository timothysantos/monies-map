{
  "name": "monies-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predev:api": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predev:ui": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "prebuild": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "prepreview": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predeploy": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predeploy:prod": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predeploy:demo": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predeploy:all": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predb:migrate": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predb:migrate:remote": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predb:migrate:demo": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "predb:empty-production": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "pretest:e2e": "node ./scripts/ensure-node-major.mjs 22.12.0",
    "dev": "concurrently -k -n API,UI \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "wrangler dev --port 8787",
    "dev:api:test": "wrangler dev --config wrangler.test.jsonc --port 8787",
    "dev:test": "npm run db:migrate:test && concurrently -k -n API,UI \"npm:dev:api:test\" \"npm:dev:ui\"",
    "dev:ui": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test tests/*.test.mjs",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "test:e2e": "playwright test",
    "verify": "npm run audit && npm run typecheck && npm run test:unit && npm run build && npm run test:e2e:smoke",
    "preview": "vite preview",
    "deploy": "npm run deploy:prod",
    "deploy:prod": "npm run build && wrangler deploy",
    "deploy:demo": "npm run build && wrangler deploy --config wrangler.demo.jsonc",
    "deploy:all": "npm run build && wrangler deploy && wrangler deploy --config wrangler.demo.jsonc",
    "test:e2e:smoke": "playwright test --workers=1 tests/e2e/api-performance.spec.js tests/e2e/month-page.spec.js tests/e2e/entries-delete-entry.spec.js tests/e2e/entries-category-filter.spec.js tests/e2e/entries-transfer-dialog.spec.js tests/e2e/import-ledger-flow.spec.js tests/e2e/summary-workflow.spec.js tests/e2e/entries-add-to-splits.spec.js tests/e2e/mobile-continuity.spec.js tests/e2e/money-field-editability.spec.js tests/e2e/reseed-contract.spec.js tests/e2e/settings-reference-data.spec.js",
    "db:migrate": "wrangler d1 execute monies-map --local --file=schema.sql",
    "db:migrate:test": "wrangler d1 execute monies-map-test --config wrangler.test.jsonc --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute monies-map --remote --file=schema.sql",
    "db:migrate:demo": "wrangler d1 execute monies-map-demo --remote --file=schema.sql",
    "db:empty-production": "node ./scripts/empty-production.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260402.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "wrangler": "^4.99.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-query": "^5.100.5",
    "lucide-react": "^1.7.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1"
  }
}
